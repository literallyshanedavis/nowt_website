# Copy to .env.local and fill in. Never commit .env.local.

# Create a key at https://resend.com/api-keys
RESEND_API_KEY=

# Full "Name <addr>" string. Sandbox default below works without domain
# verification but lands in spam more often; swap to a verified domain
# (e.g. "thirtyseven <hello@thirtyseven.app>") for production.
WAITLIST_FROM_EMAIL=thirtyseven <onboarding@resend.dev>

# Optional — address shown in the Reply-To header.
WAITLIST_REPLY_TO=

# Payload CMS
# Generate with: openssl rand -base64 32
PAYLOAD_SECRET=

# Supabase Postgres. Fill in the database password from the Supabase dashboard.
DATABASE_URL=postgresql://postgres:<YOUR-SUPABASE-DB-PASSWORD>@db.osabmpzlpbtdrzbamnut.supabase.co:5432/postgres

# Public Supabase client values.
NEXT_PUBLIC_SUPABASE_URL=https://osabmpzlpbtdrzbamnut.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xbFgCgGVT-Dh_ZzGpoq8nw_kFeZv5jw
